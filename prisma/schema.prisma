// =============================================================
//  Ochi-ss Web Order System — Prisma Schema
//  DB: PostgreSQL 16
//  命名: DBカラム=snake_case / Prismaフィールド=camelCase
//  PK: UUID v4
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
//  認証・ユーザー管理
// =============================================================

/// 得意先（企業）マスタ
model Customer {
  id                  String   @id @default(uuid())
  customerCode        String   @unique @map("customer_code") // 6桁企業コード
  customerName        String   @map("customer_name")
  customerStatus      Int      @default(1) @map("customer_status") // 1:有効 0:停止
  loginEnabled        Boolean  @default(true) @map("login_enabled")
  featureRestrictions Json?    @map("feature_restrictions") // 機能制限JSON
  allowedPages        Json?    @map("allowed_pages") // 許可ページ一覧
  sessionTimeoutMin   Int      @default(140) @map("session_timeout_min")
  maxConcurrentLogins Int      @default(5) @map("max_concurrent_logins")
  highSecurityFlag    Boolean  @default(false) @map("high_security_flag")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  isDeleted           Boolean  @default(false) @map("is_deleted")

  users            User[]
  estimates        EstimateHeader[]
  directDeliveries DirectDelivery[]

  @@map("customers")
}

/// ユーザー（企業内の担当者）
model User {
  id            String    @id @default(uuid())
  customerId    String    @map("customer_id")
  username      String // ログインID（企業内一意）
  passwordHash  String    @map("password_hash") // bcrypt コスト12
  chargeName    String?   @map("charge_name") // 担当者名
  userStatus    Int       @default(1) @map("user_status")
  accountLocked    Boolean   @default(false) @map("account_locked")
  loginFailCount   Int       @default(0) @map("login_fail_count")  // 連続失敗回数
  lockedUntil      DateTime? @map("locked_until")                   // ロック解除日時
  userRole         Int       @default(1) @map("user_role")
  // 0:Guest / 1:User / 2:Manager / 3:Admin / 4:SuperAdmin
  lastLoginAt      DateTime? @map("last_login_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  isDeleted     Boolean   @default(false) @map("is_deleted")

  customer       Customer       @relation(fields: [customerId], references: [id])
  loginHistories LoginHistory[]

  @@unique([customerId, username])
  @@map("users")
}

/// ログイン履歴（追記専用）
model LoginHistory {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  customerCode String   @map("customer_code")
  loginAt      DateTime @default(now()) @map("login_at")
  ipAddress    String   @map("ip_address")
  userAgent    String?  @map("user_agent")
  sessionId    String?  @map("session_id")
  result       Int      @map("result") // 1:成功 / 負値:失敗コード
  failReason   String?  @map("fail_reason")
  loginMethod  String?  @map("login_method")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, loginAt])
  @@map("login_histories")
}

/// セキュリティイベントログ（追記専用・削除禁止）
model SecurityLog {
  id         String   @id @default(uuid())
  eventType  String   @map("event_type")
  message    String
  ipAddress  String?  @map("ip_address")
  username   String?
  logLevel   String   @map("log_level") // DEBUG/INFO/WARNING/ERROR/ALERT
  occurredAt DateTime @default(now()) @map("occurred_at")

  @@index([occurredAt])
  @@index([logLevel, occurredAt])
  @@map("security_logs")
}

// =============================================================
//  見積・注文（基幹）
// =============================================================

/// 見積ヘッダー
model EstimateHeader {
  id                 String    @id @default(uuid())
  estimateNo         String?   @unique @map("estimate_no") // サーバー採番（8桁）
  customerId         String    @map("customer_id")
  customerCode       String    @map("customer_code")
  customerName       String    @map("customer_name")
  customerOrderNo    String?   @map("customer_order_no") // お客様注文番号
  endUserNo          String?   @map("end_user_no")
  estimateDate       DateTime? @map("estimate_date")
  inputDate          DateTime  @default(now()) @map("input_date")
  // 送り先情報
  destinationCode    String?   @map("destination_code")
  destinationName    String?   @map("destination_name")
  destinationDept    String?   @map("destination_dept")
  destinationPerson  String?   @map("destination_person")
  destinationZip     String?   @map("destination_zip")
  destinationAddress String?   @map("destination_address") // AES-256-GCM 暗号化
  destinationTel     String?   @map("destination_tel") // AES-256-GCM 暗号化
  destinationFax     String?   @map("destination_fax") // AES-256-GCM 暗号化
  // ★Web見積確認/取込機能: ヘッダー共通送り先が登録済み直送先マスタの
  //   どれに対応するかを保持する(未設定=都度入力の送り先)。
  //   SQL Server側 usp_WebDirectDelivery_resolve が優先的にこの値で解決する。
  directDeliveryId   String?   @map("direct_delivery_id")
  shippingMethodId   Int?      @map("shipping_method_id")
  requestNouki       String?   @map("request_nouki") // 希望納期（テキスト入力）
  chargeName         String?   @map("charge_name") // 担当者名
  remarks            String?
  estimateStatus     String    @default("draft") @map("estimate_status")
  // draft / saved / ordered / cancelled
  editMode           String    @default("new") @map("edit_mode")
  // new / edit / copy
  createdBy          String    @map("created_by")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  isDraftOnly        Boolean   @default(false) @map("is_draft_only") // Draft専用フラグ
  draftExpiresAt     DateTime? @map("draft_expires_at") // Draft有効期限
  draftSavedAt       DateTime? @map("draft_saved_at") // 最終自動保存日時
  draftDeviceInfo    String?   @map("draft_device_info") // 保存端末情報
  isDeleted          Boolean   @default(false) @map("is_deleted")
  // ★楽観的排他制御(優先対応2): 同時編集の後勝ち(Lost Update)を防止するための版番号。
  // PUT /api/v1/estimates/[id] は更新時に「取得時のversion」と一致する行のみを
  // 更新し、同時に version をインクリメントする。一致しない場合は
  // 他ユーザーによる更新が割り込んだとみなし 409 を返す。
  version            Int       @default(1) @map("version")

  customer   Customer         @relation(fields: [customerId], references: [id])
  directDelivery DirectDelivery? @relation(fields: [directDeliveryId], references: [id], map: "estimate_header_direct_delivery_fk")
  details    EstimateDetail[]
  // ★2026/07/14 部分注文対応: Order側のestimateHeaderIdから@uniqueを外し
  // 1見積に複数受注を許可したため、こちらも単数(Order?)から配列(Order[])に変更
  orders     Order[]
  // ★優先対応3: 見積の版管理（リビジョン履歴）
  revisions  EstimateRevision[]

  @@index([customerId, estimateStatus])
  @@index([customerId, isDraftOnly, draftExpiresAt])
  @@index([estimateNo])
  @@map("estimate_headers")
}

/// 見積明細
model EstimateDetail {
  id                  String    @id @default(uuid())
  estimateHeaderId    String    @map("estimate_header_id")
  rowNo               Int       @map("row_no")
  materialCode        String    @map("material_code")
  materialName        String?   @map("material_name")
  // 加工仕様
  kakouShiyouCode     Int       @map("kakou_shiyou_code")
  kakouShiyou         String?   @map("kakou_shiyou")
  // 加工指示コード（T/A/B）
  kakouShijiCodeT     String?   @map("kakou_shiji_code_t")
  kakouShijiCodeA     String?   @map("kakou_shiji_code_a")
  kakouShijiCodeB     String?   @map("kakou_shiji_code_b")
  kakouT              String?   @map("kakou_t")
  kakouA              String?   @map("kakou_a")
  kakouB              String?   @map("kakou_b")
  // 寸法（mm）
  sizeT               Decimal   @map("size_t") @db.Decimal(7, 3)
  sizeA               Decimal   @map("size_a") @db.Decimal(7, 3)
  sizeB               Decimal   @map("size_b") @db.Decimal(7, 3)
  // 公差（T/A/B × 上下限）
  kousaTUpper         Decimal?  @map("kousa_t_upper") @db.Decimal(6, 3)
  kousaTLower         Decimal?  @map("kousa_t_lower") @db.Decimal(6, 3)
  kousaAUpper         Decimal?  @map("kousa_a_upper") @db.Decimal(6, 3)
  kousaALower         Decimal?  @map("kousa_a_lower") @db.Decimal(6, 3)
  kousaBUpper         Decimal?  @map("kousa_b_upper") @db.Decimal(6, 3)
  kousaBLower         Decimal?  @map("kousa_b_lower") @db.Decimal(6, 3)
  // 面取り
  mentoriShiji        String?   @map("mentori_shiji")
  mentori4            Decimal?  @map("mentori_4") @db.Decimal(5, 2)
  mentori8            Decimal?  @map("mentori_8") @db.Decimal(5, 2)
  // 数量
  quantity            Int
  // 計算結果
  unitPrice           Decimal?  @map("unit_price") @db.Decimal(12, 2)
  totalPrice          Decimal?  @map("total_price") @db.Decimal(14, 2)
  shortestDelivery    String?   @map("shortest_delivery")
  deliveryDeadline    DateTime? @map("delivery_deadline")
  // ★2026/07/14 追加: 明細単位の個別直送先（未設定時は見積ヘッダーの共通送り先を使用）
  useIndividualDestination Boolean @default(false) @map("use_individual_destination")
  // ★Web見積確認/取込機能: 明細単位の個別直送先が登録済み直送先マスタの
  //   どれに対応するかを保持する(未設定=都度入力の送り先)。
  indivDirectDeliveryId String? @map("indiv_direct_delivery_id")
  destinationCode     String?   @map("indiv_destination_code")
  destinationName     String?   @map("indiv_destination_name")
  destinationDept     String?   @map("indiv_destination_dept")
  destinationPerson   String?   @map("indiv_destination_person")
  destinationZip      String?   @map("indiv_destination_zip")
  destinationAddress  String?   @map("indiv_destination_address")
  destinationTel      String?   @map("indiv_destination_tel")
  destinationFax      String?   @map("indiv_destination_fax")
  // ★2026/07/14 部分注文対応: 明細単位の注文済み管理。
  // 見積ヘッダーのestimateStatusに頼らず、明細自身がどの受注に属するかを持つ。
  orderId             String?   @map("order_id")
  orderedOrderNo      String?   @map("ordered_order_no")
  // 計算中間値（デバッグ・監査用）
  materialSizeT       Decimal?  @map("material_size_t") @db.Decimal(7, 3)
  materialSizeA       Decimal?  @map("material_size_a") @db.Decimal(7, 3)
  materialSizeB       Decimal?  @map("material_size_b") @db.Decimal(7, 3)
  materialUnitWeight  Decimal?  @map("material_unit_weight") @db.Decimal(10, 4)
  materialTotalWeight Decimal?  @map("material_total_weight") @db.Decimal(10, 4)
  productUnitWeight   Decimal?  @map("product_unit_weight") @db.Decimal(10, 4)
  productTotalWeight  Decimal?  @map("product_total_weight") @db.Decimal(10, 4)
  processingCost6f    Decimal?  @map("processing_cost_6f") @db.Decimal(12, 2)
  processingCostTotal Decimal?  @map("processing_cost_total") @db.Decimal(12, 2)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  isDeleted Boolean  @default(false) @map("is_deleted")

  estimateHeader EstimateHeader @relation(fields: [estimateHeaderId], references: [id])
  indivDirectDelivery DirectDelivery? @relation("IndivDirectDelivery", fields: [indivDirectDeliveryId], references: [id], map: "estimate_detail_indiv_direct_delivery_fk")

  @@unique([estimateHeaderId, rowNo])
  @@index([estimateHeaderId])
  @@map("estimate_details")
}

/// 見積リビジョン履歴（優先対応3: 見積の版管理）
/// PUT /api/v1/estimates/[id] で上書き保存される直前のヘッダー・明細一式を
/// JSONスナップショットとして保存する。改ざん調査・復元用の監査証跡のため、
/// 削除しない(isDeletedを持たない)。
model EstimateRevision {
  id               String   @id @default(uuid())
  estimateHeaderId String   @map("estimate_header_id")
  // 上書きされる直前にヘッダーが持っていたversion値
  // (EstimateHeader.versionと対応。version=1の初期保存後の最初の編集で
  //  versionNo=1のスナップショットが作られ、ヘッダーはversion=2になる)
  versionNo        Int      @map("version_no")
  headerSnapshot   Json     @map("header_snapshot")
  detailsSnapshot  Json     @map("details_snapshot")
  changedBy        String   @map("changed_by")
  changeReason     String?  @map("change_reason")
  createdAt        DateTime @default(now()) @map("created_at")

  estimateHeader EstimateHeader @relation(fields: [estimateHeaderId], references: [id])

  @@index([estimateHeaderId, versionNo])
  @@map("estimate_revisions")
}

/// 注文（発注確定）
model Order {
  id               String    @id @default(uuid())
  orderNo          String?   @unique @map("order_no") // 業務側採番後に設定
  estimateHeaderId String    @map("estimate_header_id") // 部分注文対応: 1見積に複数受注を許可
  customerId       String    @map("customer_id")
  orderDate        DateTime  @default(now()) @map("order_date")
  orderStatus      String    @default("pending") @map("order_status")
  // pending / confirmed / in_progress / shipped / completed / cancelled
  totalAmount      Decimal?  @map("total_amount") @db.Decimal(14, 2)
  detailCount      Int?      @map("detail_count")
  trackingNo       String?   @map("tracking_no") // 送り状番号
  confirmedAt      DateTime? @map("confirmed_at")
  // ★usp_WebEstimateImport_exec の実行結果(WEB進捗通知 通知種別=
  //   'number_assigned')をpolling.worker.tsが反映する列。
  //   orderNoはWeb側採番(Z+日付+連番)のままなので、業務システム側の
  //   実際の受注No/売上Noはこちらに別途保持する。
  businessOrderNo   String?   @map("business_order_no")
  businessSalesNo   String?   @map("business_sales_no")
  businessImportedAt DateTime? @map("business_imported_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  isDeleted        Boolean   @default(false) @map("is_deleted")

  estimateHeader  EstimateHeader       @relation(fields: [estimateHeaderId], references: [id])
  statusHistories OrderStatusHistory[]
  specChanges     SpecChangeHistory[]

  @@index([customerId, orderStatus])
  @@index([estimateHeaderId])
  @@map("orders")
}

// =============================================================
//  マスタ
// =============================================================

/// 直送先マスタ（得意先ごとに管理）
model DirectDelivery {
  id                String   @id @default(uuid())
  customerId        String   @map("customer_id")
  customerCode      String   @map("customer_code")
  deliveryCode      String   @map("delivery_code")
  companyName       String   @map("company_name")
  furigana          String?
  shortName         String?  @map("short_name")
  corporateType     String?  @map("corporate_type")
  corporatePosition String?  @map("corporate_position")
  departmentName    String?  @map("department_name")
  contactPerson     String?  @map("contact_person")
  postalCode        String?  @map("postal_code")
  address1          String?  @map("address1") // AES-256-GCM 暗号化
  address2          String?  @map("address2") // AES-256-GCM 暗号化
  address3          String?  @map("address3") // AES-256-GCM 暗号化
  phoneNumber       String?  @map("phone_number") // AES-256-GCM 暗号化
  faxNumber         String?  @map("fax_number") // AES-256-GCM 暗号化
  remarks           String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  isDeleted         Boolean  @default(false) @map("is_deleted")

  customer Customer @relation(fields: [customerId], references: [id])
  estimateHeaders EstimateHeader[]
  estimateDetailsIndiv EstimateDetail[] @relation("IndivDirectDelivery")

  @@unique([customerCode, deliveryCode])
  @@map("direct_deliveries")
}

/// 材料マスタ（SQL Serverからの複製キャッシュ）
model Material {
  id           String   @id @default(uuid())
  materialCode String   @unique @map("material_code")
  materialName String   @map("material_name")
  syncedAt     DateTime @default(now()) @map("synced_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("materials")
}

/// 加工仕様マスタ（複製キャッシュ）
model ProcessingSpec {
  id                 String   @id @default(uuid())
  processingSpecCode Int      @unique @map("processing_spec_code")
  processingSpecName String   @map("processing_spec_name")
  kakouShijiT        String   @default("W") @map("kakou_shiji_t") // 厚み面デフォルト加工指示
  kakouShijiA        String   @default("W") @map("kakou_shiji_a") // 巾面デフォルト加工指示
  kakouShijiB        String   @default("W") @map("kakou_shiji_b") // 長さ面デフォルト加工指示
  syncedAt           DateTime @default(now()) @map("synced_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("processing_specs")
}

/// お知らせ
model Notification {
  id              String    @id @default(uuid())
  title           String
  content         String
  notifType       String    @map("notif_type") // info / warning / urgent
  targetCustomers Json?     @map("target_customers") // null=全顧客
  publishedAt     DateTime? @map("published_at")
  expiresAt       DateTime? @map("expires_at")
  createdBy       String    @map("created_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  isDeleted       Boolean   @default(false) @map("is_deleted")

  @@index([publishedAt, expiresAt])
  @@map("notifications")
}

// =============================================================
//  Sync / Audit テーブル
// =============================================================

/// Transactional Outbox（Web→業務への送信キュー）
model OutboxEvent {
  id            String    @id @default(uuid())
  aggregateType String    @map("aggregate_type") // estimate / order
  aggregateId   String    @map("aggregate_id") // EstimateHeader.id or Order.id
  eventType     String    @map("event_type")
  // estimate.created / order.placed / order.cancelled など
  payload       Json
  status        String    @default("pending") @map("status")
  // pending / processing / sent / failed / dead_letter
  retryCount    Int       @default(0) @map("retry_count")
  lastAttemptAt DateTime? @map("last_attempt_at")
  sentAt        DateTime? @map("sent_at")
  errorMessage  String?   @map("error_message")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // ★2026/07/21 修正: aggregateId は estimate/order 兼用のポリモーフィックIDのため、
  //   単純な外部キー制約では両方を同時に満たせない(片方は必ず違反する)。
  //   estimateHeader/orderへのFKリレーションは撤廃し、整合性はアプリケーション側で担保する。
  //   (この2行のFKが原因で、outboxEvent.create()が常にP2003で失敗し、
  //   Web→業務システムへの同期が一度も成立していなかった)

  @@index([status, createdAt])
  @@map("outbox_events")
}

/// 注文ステータス変更履歴（業務→Web / 追記専用）
model OrderStatusHistory {
  id           String    @id @default(uuid())
  orderId      String    @map("order_id")
  fromStatus   String?   @map("from_status")
  toStatus     String    @map("to_status")
  changedBy    String    @map("changed_by") // "system" または担当者識別子
  changeSource String    @map("change_source") // "web" / "business_system"
  changeReason String?   @map("change_reason")
  trackingNo   String?   @map("tracking_no") // 送り状番号
  notifiedAt   DateTime? @map("notified_at")
  occurredAt   DateTime  @default(now()) @map("occurred_at")

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId, occurredAt])
  @@map("order_status_histories")
}

/// 仕様変更履歴（業務→Web / 追記専用）
model SpecChangeHistory {
  id            String    @id @default(uuid())
  orderId       String    @map("order_id")
  rowNo         Int       @map("row_no")
  fieldName     String    @map("field_name") // 変更されたフィールド名
  oldValue      String?   @map("old_value")
  newValue      String    @map("new_value")
  changeReason  String?   @map("change_reason") // 業務側担当者が記入した変更理由
  changedBy     String    @map("changed_by")
  changeSource  String    @map("change_source") // "web" / "business_system"
  webNotifiedAt DateTime? @map("web_notified_at") // Web顧客への通知日時
  occurredAt    DateTime  @default(now()) @map("occurred_at")

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId, occurredAt])
  @@map("spec_change_histories")
}

/// 全同期イベント査証ログ（削除禁止・isDeletedなし）
model SyncChangeLog {
  id           String   @id @default(uuid())
  direction    String   @map("direction") // "web_to_biz" / "biz_to_web"
  eventType    String   @map("event_type")
  sourceTable  String   @map("source_table")
  targetTable  String   @map("target_table")
  recordId     String   @map("record_id")
  payload      Json?
  status       String   @map("status") // success / failed
  errorMessage String?  @map("error_message")
  processedAt  DateTime @default(now()) @map("processed_at")
  durationMs   Int?     @map("duration_ms")

  @@index([direction, processedAt])
  @@index([recordId])
  @@map("sync_change_logs")
}

model ChamferRule {
  id                 String   @id @default(cuid())
  materialCode       String   @db.VarChar(4)
  processingSpecCode Int
  sizeAFrom          Decimal? @db.Decimal(7, 3)
  sizeATo            Decimal? @db.Decimal(7, 3)
  sizeBFrom          Decimal? @db.Decimal(7, 3)
  sizeBTo            Decimal? @db.Decimal(7, 3)
  limitChamfer4      Decimal? @db.Decimal(7, 3)
  limitChamfer8      Decimal? @db.Decimal(7, 3)
  maxChamfer4        Decimal? @db.Decimal(7, 3)
  maxChamfer8        Decimal? @db.Decimal(7, 3)
  priority           Int      @default(0)
  isDeleted          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("chamfer_rules")
}

/// お知らせ既読管理
model NotificationRead {
  id             String   @id @default(uuid())
  notificationId String   @map("notification_id")
  customerId     String   @map("customer_id")
  readAt         DateTime @default(now()) @map("read_at")

  @@unique([notificationId, customerId])
  @@index([customerId])
  @@map("notification_reads")
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("system_settings")
}

/// 操作監査ログ（追記専用・削除禁止）
model AuditLog {
  id          String   @id @default(uuid())
  customerId  String   @map("customer_id")
  userId      String   @map("user_id")
  action      String                        // READ/CREATE/UPDATE/DELETE/EXPORT/AUTH
  resource    String                        // estimates/orders/direct_deliveries/pdf
  resourceId  String?  @map("resource_id")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  resultCode  Int      @default(200) @map("result_code")
  detail      Json?
  occurredAt  DateTime @default(now()) @map("occurred_at")

  @@index([customerId, occurredAt])
  @@index([userId, occurredAt])
  @@index([resource, resourceId])
  @@map("audit_logs")
}
