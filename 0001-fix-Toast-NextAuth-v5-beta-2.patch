+// POST /api/v1/auth/login — カスタム認証API
+// NextAuth v5 は authorize() の throw を "CredentialsSignin" に上書きするため、
+// エラーコード別メッセージをクライアントに返すカスタムAPIを使用する。
+import { NextRequest, NextResponse } from "next/server"
+import bcrypt from "bcryptjs"
+import { z } from "zod"
+import { prisma } from "@/lib/prisma"
+
+const schema = z.object({
+  companyCode: z.string().regex(/^\d{5}$/, "企業コードは5桁の数字です"),
+  userId:      z.string().min(1).max(50).regex(/^[\x21-\x7E]+$/),
+  password:    z.string().min(1).max(50),
+})
+
+const ERRORS: Record<string, string> = {
+  "INVALID_INPUT":    "入力内容を確認してください",
+  "COMPANY_NOT_FOUND":"企業コードが正しくありません",
+  "COMPANY_DISABLED": "この企業のログインは現在無効です。管理者にお問い合わせください",
+  "USER_NOT_FOUND":   "ユーザーIDまたはパスワードが正しくありません",
+  "ACCOUNT_LOCKED":   "アカウントがロックされています。30分後に再度お試しください",
+  "USER_DISABLED":    "このアカウントは無効です。管理者にお問い合わせください",
+  "WRONG_PASSWORD":   "ユーザーIDまたはパスワードが正しくありません",
+}
+
+export async function POST(req: NextRequest) {
+  const body = await req.json().catch(() => null)
+  const parsed = schema.safeParse(body)
+  if (!parsed.success) {
+    return NextResponse.json({ error: "INVALID_INPUT", message: ERRORS["INVALID_INPUT"] }, { status: 400 })
+  }
+  const { companyCode, userId, password } = parsed.data
+
+  // 企業確認
+  const customer = await prisma.customer.findFirst({
+    where: { customerCode: { startsWith: companyCode }, isDeleted: false },
+    select: { id: true, customerCode: true, customerName: true, loginEnabled: true, sessionTimeoutMin: true },
+  })
+  if (!customer) {
+    return NextResponse.json({ error: "COMPANY_NOT_FOUND", message: ERRORS["COMPANY_NOT_FOUND"] }, { status: 401 })
+  }
+  if (!customer.loginEnabled) {
+    return NextResponse.json({ error: "COMPANY_DISABLED", message: ERRORS["COMPANY_DISABLED"] }, { status: 401 })
+  }
+
+  // ユーザー確認
+  const user = await prisma.user.findFirst({
+    where: { customerId: customer.id, username: userId, isDeleted: false },
+    select: { id: true, username: true, passwordHash: true, userStatus: true, accountLocked: true, loginFailCount: true, lockedUntil: true, userRole: true, chargeName: true },
+  })
+  if (!user) {
+    return NextResponse.json({ error: "USER_NOT_FOUND", message: ERRORS["USER_NOT_FOUND"] }, { status: 401 })
+  }
+
+  // ロック自動解除
+  if (user.accountLocked && user.lockedUntil && new Date() > new Date(user.lockedUntil)) {
+    await prisma.user.update({ where: { id: user.id }, data: { accountLocked: false, loginFailCount: 0, lockedUntil: null } })
+    user.accountLocked = false
+  }
+  if (user.accountLocked) {
+    return NextResponse.json({ error: "ACCOUNT_LOCKED", message: ERRORS["ACCOUNT_LOCKED"] }, { status: 401 })
+  }
+  if (user.userStatus !== 1) {
+    return NextResponse.json({ error: "USER_DISABLED", message: ERRORS["USER_DISABLED"] }, { status: 401 })
+  }
+
+  // パスワード検証
+  const ok = await bcrypt.compare(password, user.passwordHash)
+  if (!ok) {
+    const newFail = (user.loginFailCount ?? 0) + 1
+    const lock    = newFail >= 5
+    await prisma.user.update({
+      where: { id: user.id },
+      data: { loginFailCount: newFail, ...(lock && { accountLocked: true, lockedUntil: new Date(Date.now() + 30*60*1000) }) },
+    })
+    const errCode = lock ? "ACCOUNT_LOCKED" : "WRONG_PASSWORD"
+    return NextResponse.json({ error: errCode, message: ERRORS[errCode] }, { status: 401 })
+  }
+
+  // 成功 — 失敗カウントリセット
+  await prisma.user.update({ where: { id: user.id }, data: { loginFailCount: 0, lockedUntil: null, lastLoginAt: new Date() } })
+
+  // OK を返す（実際のセッション確立は NextAuth の signIn() が行う）
+  return NextResponse.json({ ok: true })
+}
