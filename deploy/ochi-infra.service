[Unit]
Description=Ochi-ss Infrastructure (PostgreSQL + Redis)
Requires=docker.service
After=docker.service network-online.target

[Service]
Type=simple
User=karkyon
WorkingDirectory=/home/karkyon/projects/ochi-ss/docker
ExecStart=/usr/bin/docker compose up
ExecStop=/usr/bin/docker compose down
Restart=on-failure
RestartSec=10s

[Install]
WantedBy=multi-user.target
