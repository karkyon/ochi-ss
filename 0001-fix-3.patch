 .../(app)/estimates/new/EstimateNewClient.tsx | 41 +++++++++++++++----
 src/app/(app)/orders/[id]/page.tsx            |  6 +--
 src/app/api/v1/estimates/[id]/route.ts        |  3 +-
 3 files changed, 37 insertions(+), 13 deletions(-)

