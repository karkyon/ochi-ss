+  const [shippingMethod, setShippingMethod] = useState(String(copySource?.shippingMethod ?? "1"))
   // 送り先
   const [distCode,      setDistCode]     = useState(copySource?.destinationCode ?? "")
   const [distName,      setDistName]     = useState(copySource?.destinationName ?? "")
@@ -189,17 +189,40 @@ export default function EstimateNewClient({ materials, processingSpecs, cuttingM
   const handleSave = async () => {
     setSaving(true); setSaveMsg("保存中...")
     try {
+      // API(SaveHeaderRequest)はフラット構造を要求するため、旧来の header:{...} 入れ子は使わない。
+      // header 入れ子だと body.inputDate が undefined になり常に 400 エラーで失敗していた。
       const payload = {
-        estimateId: currentDraftId,
-        header: { inputDate, estimateDate, shippingMethod, destinationCode: distCode, destinationName: distName, destinationDept: distDept, destinationPerson: distPerson, destinationZip: distZip, destinationAddress: distAddr, destinationTel: distTel, destinationFax: distFax, contact, customerOrderNo: custOrderNo, endUserNo },
+        inputDate,
+        estimateDate,
+        shippingMethodId: Number(shippingMethod) || null,
+        destinationCode: distCode || undefined,
+        destinationName: distName || undefined,
+        destinationDept: distDept || undefined,
+        destinationPerson: distPerson || undefined,
+        destinationZip: distZip || undefined,
+        destinationAddress: distAddr || undefined,
+        destinationTel: distTel || undefined,
+        destinationFax: distFax || undefined,
+        remarks: contact || undefined,
+        customerOrderNo: custOrderNo || undefined,
+        endUserNo: endUserNo || undefined,
+        editMode: currentDraftId ? "Edit" as const : "New" as const,
         details: details.map((d, i) => ({ ...d, rowNo: i + 1 })),
       }
-      const res = await fetch("/api/v1/estimates", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) })
-      if (!res.ok) throw new Error("保存失敗")
+      // 既存見積(編集中)ならPUTで更新、新規ならPOSTで作成
+      const isEdit = !!currentDraftId
+      const url    = isEdit ? `/api/v1/estimates/${currentDraftId}` : "/api/v1/estimates"
+      const method = isEdit ? "PUT" : "POST"
+      const res = await fetch(url, { method, headers: { "Content-Type": "application/json" }, body: JSON.stringify(payload) })
+      if (!res.ok) {
+        const errBody = await res.json().catch(() => ({}))
+        throw new Error(errBody?.error ?? "保存失敗")
+      }
       const data = await res.json()
       setCurrentDraftId(data.estimateId)
-      setEstimateNo(data.estimateNo ?? "")
-      setSaveMsg(`✅ 保存完了！見積番号: ${data.estimateNo}`)
+      const savedNo = data.estimateNo ?? estimateNo
+      setEstimateNo(savedNo)
+      setSaveMsg(`✅ 保存完了！見積番号: ${savedNo}`)
     } catch (e: any) { setSaveMsg("❌ 保存失敗: " + e.message) }
     finally { setSaving(false); setTimeout(() => setSaveMsg(""), 4000) }
   }
